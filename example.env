# Core API
VITE_API_BASE_URL=http://localhost:8081

# Optional: Agent endpoint (DigitalOcean, etc.)
# Set in your local `.env`; leave blank in this template.
VITE_AGENT_API_BASE_URL=
# Access key used as: Authorization: Bearer <key>
VITE_AGENT_ACCESS_KEY=
# Browser-facing path used by conversations/chat calls.
VITE_AGENT_API_PATH=/v1/chat/completions

# Categories (comma-separated)
VITE_CATEGORIES=Social,Civic,Miata,Dining Out,Home,Gifts,Nonperishables,Games,Groceries,Clothes,Gas,Automotive,Healthcare,Photography,Contraband,Utility,Work,Subscription,Outdoors,Movie Rental,Girlfriend,Vacation,Book,Technology,Music,Haircut,Pet,Leisure,Career Development,Coding,Reimbursement

# Payment methods (comma-separated)
VITE_PAYMENT_METHODS=Sapphire,Freedom,Amex

# Maps (JSON)
VITE_BANK_PAYMENT_METHOD_MAP={"Sapphire":"Chase Sapphire","Freedom":"Chase Freedom","Amex":"Amex"}
VITE_DEFAULT_CRITICALITY_MAP={"Dining Out":"Essential","Nonperishables":"Essential","Groceries":"Essential","Gas":"Essential","Healthcare":"Essential","Utility":"Essential","Haircut":"Essential","Pet":"Essential","Social":"Nonessential","Civic":"Nonessential","Miata":"Nonessential","Home":"Nonessential","Gifts":"Nonessential","Games":"Nonessential","Clothes":"Nonessential","Automotive":"Nonessential","Photography":"Nonessential","Contraband":"Nonessential","Work":"Nonessential","Subscription":"Nonessential","Outdoors":"Nonessential","Movie Rental":"Nonessential","Girlfriend":"Nonessential","Vacation":"Nonessential","Book":"Nonessential","Technology":"Nonessential","Music":"Nonessential","Leisure":"Nonessential","Career Development":"Nonessential","Coding":"Nonessential","Reimbursement":"Nonessential"}
VITE_DEFAULT_PAYMENT_METHOD_MAP={"joint":"Sapphire","josh":"Freedom","anna":"Amex"}

# Optional preview hosts for `vite preview`
# VITE_PREVIEW_ALLOWED_HOSTS=localhost,127.0.0.1
# VITE_ALLOWED_HOSTS=localhost,127.0.0.1

